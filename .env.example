# Hyperliquid Exchange API Configuration
# Copy this file to .env and fill in your actual values

# Required: Hyperliquid API secret key for trading
# Generate this from your Hyperliquid account settings
HYPERLIQUID_API_SECRET=your_private_key_here

# Optional: Hyperliquid account address
# If not specified, uses the default vault address
HYPERLIQUID_ACCOUNT_ADDRESS=your_account_address_here

# Development Settings
# Set to "true" to enable debug logging and additional metrics
DEBUG=false

# Data Directory
# Directory for storing CSV cache files (default: data/)
# DATA_DIR=data

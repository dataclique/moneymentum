{
  "name": "moneymentum",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0 --cache --cache-location .eslintcache",
    "lint:staged": "eslint --max-warnings=0 --cache --cache-location .eslintcache",
    "preview": "vite preview",
    "serve:spa": "bunx serve -s dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "fmt": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/syne": "^5.2.7",
    "@kobalte/core": "^0.13.9",
    "@nktkas/hyperliquid": "^0.33.2",
    "@reown/appkit": "^1.8.22",
    "@reown/appkit-adapter-ethers": "^1.8.22",
    "@solidjs/router": "^0.15.3",
    "@tanstack/solid-query": "^5.90.9",
    "@tanstack/solid-table": "^8.21.3",
    "@tanstack/solid-virtual": "^3.13.13",
    "ccxt": "^4.5.42",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "effect": "^3.21.4",
    "lightweight-charts": "^5.1.0",
    "lucide-solid": "^0.577.0",
    "multicoin-address-validator": "^0.5.26",
    "protobufjs": "^8.0.0",
    "solid-js": "^1.9.5",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.55.2"
